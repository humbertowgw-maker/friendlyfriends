# AI Provider API Keys (add your keys here, then rename to .env)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GEMINI_API_KEY=
OPENROUTER_API_KEY=

# Optional: custom endpoints for OSS models
OLLAMA_BASE_URL=http://localhost:11434
LM_STUDIO_BASE_URL=http://localhost:1234

# Image Generation (pick one or more — tried in priority order)
# Local Stable Diffusion WebUI (Automatic1111)
SD_WEBUI_URL=http://127.0.0.1:7860
# ComfyUI (overrides SD_WEBUI_URL if set)
COMFYUI_URL=
# HuggingFace free tier (optional)
HF_API_TOKEN=
HF_MODEL=stabilityai/stable-diffusion-xl-base-1.0
# Pollinations.ai — always available, no key needed (fallback)

# Server
PORT=3001
