{
  "name": "ai-rate-gauge",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Self-aware AI rate gauge dashboard - tracks costs, rate limits, and optimizes model usage",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node server/index.js",
    "client": "cd client && npm run dev",
    "setup": "npm install && cd client && npm install",
    "build": "cd client && npm run build"
  },
  "dependencies": {
    "sql.js": "^1.12.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
